# Defesa em profundidade: nunca executar PHP em arquivos sob /uploads/
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|phar|cgi|pl|py|sh|jsp|asp|aspx)$">
    Require all denied
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>

RemoveHandler  .php .phtml .phar
RemoveType     .php .phtml .phar
SetHandler     default-handler

Options -ExecCGI -Indexes
