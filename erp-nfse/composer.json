{
    "name": "multimaquinas/erp-nfse",
    "description": "ERP Assistência Técnica com emissão de NFS-e",
    "type": "project",
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "nfse-nacional/nfse-php": "^1.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "worker": "php scripts/worker.php",
        "reconciliar": "php scripts/reconciliar_notas.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}